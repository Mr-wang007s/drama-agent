{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/session-start.js"
          }
        ],
        "description": "进入会话时提示当前系列状态"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "tool == \"Edit\" || tool == \"Write\"",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/pre-tool-use.js"
          }
        ],
        "description": "保护 canon 文件，避免未经确认的改写"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "tool == \"Edit\" || tool == \"Write\"",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/post-tool-use.js"
          }
        ],
        "description": "记录写入类工具事件"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/pre-compact.js"
          }
        ],
        "description": "上下文压缩前记录状态"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/hooks/session-end.js"
          }
        ],
        "description": "会话结束时保存运行日志"
      }
    ]
  }
}
